# Models (large, fetched by download_models.ps1)
models/
*.gguf
*.onnx
*.onnx_data
*.safetensors

# Sibling llama.cpp checkout and build dirs
llama.cpp/
build-*/

# Python venv
.venv/
.venv-*/
__pycache__/
*.pyc
.ipynb_checkpoints/

# Results — keep the directory, ignore contents initially
# (uncomment if you want git-tracked results)
# results/*.csv
# results/*.log

# Large per-step logit / KV dumps — regenerable from scripts; tracked .md
# reports next to them carry the human-readable findings.
results/*.npz

# QAIRT compile intermediates (DLCs, .bins, DLC-JSON dumps, output dirs) —
# large and regenerable. The .log/.md files in the same dir ARE tracked.
results/**/*.dlc
results/**/*.dlc.json
results/**/*.bin
results/**/*.bin.info.json
results/**/output/

# Editor
.vscode/
.idea/
*.swp

# Built probe binaries (source + build script tracked, binary not)
scripts/sme_probe/*.exe
scripts/sme_probe/*.obj
scripts/sme_probe/*.pdb

# OS
Thumbs.db
.DS_Store

# QNN runtime trace dropped in CWD by every ORT-QNN session
# (sidecar / http_server / oracle scripts). Large binary log,
# regenerable, contains nothing we'd want to track.
_qnn.log

# Cleanup staging — large artifacts pending hard delete
marked_for_deletion/

# SQ4 cloud-adventure run artifacts:
#  - qsim.json (AIMET v2 encodings, 60-150 MB each, regeneratable from
#    aimet_quant.py + the HF model + the cal prompts)
#  - run logs (raw stdout; signal lives in findings.md)
# Manifests (manifest.json) are small and ARE tracked — they are the
# reproducibility anchor.
last_side_quest/sq4_cloud_adventure/runs/*/qsim.json
last_side_quest/sq4_cloud_adventure/runs/*/qsim.encodings.json
last_side_quest/sq4_cloud_adventure/runs/*.log
last_side_quest/sq4_cloud_adventure/runs/*/qsim_model.onnx
last_side_quest/sq4_cloud_adventure/runs/*/qsim_model.data
