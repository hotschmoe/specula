ï»¿def binary_search(arr, target):
    # Return the index of target in arr, or -1 if not found
    
    left = 0
    right = len(arr) - 1
    
    while left <= right:
        mid = (left + right) // 2
        if arr[mid] == target:
            return mid
        elif arr[mid] < target:
            left = mid + 1
        else:
            right = mid - 1
    return -1

# Example usage:
arr = [1, 3, 5, 7, 9]
target = 5
index = binary_search(arr, target)
print(f"Index of {target} is {index}")  # Output: Index of 5 is 2

target = 8
index = binary_search(arr, target)
print(f"Index of {target} is {index}")  # Output: Index of 8 is -1

# This function performs a binary search on a sorted array. It starts with the entire array and repeatedly divides the search interval in half. If the middle element is equal to the target, it returns the index. If the middle element is less than the target, the search continues in the right half; otherwise, it continues in the left half. If the target is not found, it returns -1. The time




